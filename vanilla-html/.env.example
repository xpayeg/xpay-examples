# Get these from your XPay dashboard → Developers → API keys.

# Your publishable key. Safe to expose to the browser; the server emits
# it to each page via /config.js so the HTML files don't have to be edited.
XPAY_PUBLISHABLE_KEY=pk_test_xxx

# Your secret key (server-side only — never exposed to the browser).
XPAY_SECRET_KEY=sk_test_xxx

# Public URL of this server. Used to build the success-redirect URL.
# Locally this is http://localhost:4242.
APP_URL=http://localhost:4242
