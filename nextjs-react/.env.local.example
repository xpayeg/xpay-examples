# Get these from your XPay dashboard → Developers → API keys.

# Your secret key (server-side only — never expose to the browser).
XPAY_SECRET_KEY=sk_test_xxx

# Your publishable key. Exposed to the browser via Next's `NEXT_PUBLIC_` prefix.
NEXT_PUBLIC_XPAY_PUBLISHABLE_KEY=pk_test_xxx

# Your webhook signing secret (from Developers → Webhooks → endpoint details).
XPAY_WEBHOOK_SECRET=whsec_xxx

# Public URL of THIS app — used to build the success-redirect URL after
# checkout completes. Locally this is http://localhost:3000; in production
# set it to your deployed domain (e.g. https://store.example.com).
NEXT_PUBLIC_APP_URL=http://localhost:3000
